# Public Supabase values. These are safe for the browser but keep the file as a template.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Server-only secret. Required for creating customer portal accounts.
# Never prefix it with NEXT_PUBLIC_ and never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Canonical application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
